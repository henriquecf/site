<% content_for(:title, "Blog — Henrique Cardoso de Faria") %>
<% content_for(:description, "Writing about Ruby on Rails, Elixir, AI, and software engineering.") %>

<% content_for(:head) do %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Blog — Henrique Cardoso de Faria",
  "description": "Writing about Ruby on Rails, Elixir, AI, and software engineering.",
  "url": "<%= blog_url %>",
  "author": {
    "@type": "Person",
    "@id": "https://hencf.org/#person",
    "name": "Henrique Cardoso de Faria"
  },
  "blogPost": [
    <% @all_posts.each_with_index do |post, i| %>
    {
      "@type": "BlogPosting",
      "headline": "<%= j post.title %>",
      "url": "<%= post_url(slug: post.slug) %>",
      "datePublished": "<%= post.published_at.iso8601 %>"
    }<%= "," unless i == @all_posts.size - 1 %>
    <% end %>
  ]
}
</script>
<% end %>

<%= render "shared/nav", active: :blog, home: false %>

<main>
  <section class="section hero">
    <div class="container">
      <h1 class="uses-heading">Blog</h1>
      <p class="uses-intro">
        Writing about Ruby on Rails, Elixir, AI, and software engineering.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <%= form_with url: blog_path, method: :get, data: { controller: "search", turbo_frame: "posts", turbo_action: "advance" } do |f| %>
        <%= f.search_field :q, value: params[:q], placeholder: "Search posts…", class: "search-input", autocomplete: "off", data: { search_target: "input", action: "input->search#search" } %>
      <% end %>

      <%= render "posts_page", posts: @posts, next_page: @next_page, page: @page, query: params[:q] %>
    </div>
  </section>
</main>

<footer class="footer">
  <div class="container">
    <p>
      Henrique Cardoso de Faria · <%= Date.current.year %>
      · <a href="<%= blog_feed_path %>">RSS feed</a>
    </p>
  </div>
</footer>
