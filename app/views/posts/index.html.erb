<% content_for(:title, "Blog — Henrique Cardoso de Faria") %>
<% content_for(:description, "Writing about Ruby on Rails, Elixir, AI, and software engineering.") %>

<% content_for(:head) do %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Blog — Henrique Cardoso de Faria",
  "description": "Writing about Ruby on Rails, Elixir, AI, and software engineering.",
  "url": "<%= blog_url %>",
  "author": {
    "@type": "Person",
    "@id": "https://hencf.org/#person",
    "name": "Henrique Cardoso de Faria"
  },
  "blogPost": [
    <% @posts.each_with_index do |post, i| %>
    {
      "@type": "BlogPosting",
      "headline": "<%= j post.title %>",
      "url": "<%= post_url(slug: post.slug) %>",
      "datePublished": "<%= post.published_at.iso8601 %>"
    }<%= "," unless i == @posts.size - 1 %>
    <% end %>
  ]
}
</script>
<% end %>

<%= render "shared/nav", active: :blog, home: false %>

<main>
  <section class="section hero">
    <div class="container">
      <h1 class="uses-heading">Blog</h1>
      <p class="uses-intro">
        Writing about Ruby on Rails, Elixir, AI, and software engineering.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <% if @posts.any? %>
        <div class="posts-list">
          <% @posts.each do |post| %>
            <article class="post-preview">
              <time class="post-date" datetime="<%= post.published_at.iso8601 %>">
                <%= post.published_at.strftime("%B %-d, %Y") %>
              </time>
              <h2 class="post-preview-title">
                <a href="<%= post_path(slug: post.slug) %>"><%= post.title %></a>
              </h2>
              <p class="post-excerpt"><%= post.description_or_fallback %></p>
            </article>
          <% end %>
        </div>
      <% else %>
        <p class="post-empty">No posts yet. Check back soon.</p>
      <% end %>
    </div>
  </section>
</main>

<footer class="footer">
  <div class="container">
    <p>Henrique Cardoso de Faria · <%= Date.current.year %></p>
  </div>
</footer>
