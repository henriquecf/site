<% content_for(:title, "#{@post.title} — Henrique Cardoso de Faria") %>
<% content_for(:description, @post.description_or_fallback) %>
<% content_for(:og_type, "article") %>
<% content_for(:og_image, @post.og_image) %>
<% content_for(:og_image_dimensions) do %>
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
<% end %>

<% content_for(:article_meta) do %>
    <meta property="article:published_time" content="<%= @post.published_at.iso8601 %>">
    <meta property="article:modified_time" content="<%= @post.modified_at.iso8601 %>">
    <meta property="article:author" content="https://hencf.org">
<% end %>

<% content_for(:head) do %>
<script type="application/ld+json">
[
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "<%= @post.title %>",
    "description": "<%= j @post.description_or_fallback %>",
    "datePublished": "<%= @post.published_at.iso8601 %>",
    "dateModified": "<%= @post.modified_at.iso8601 %>",
    "url": "<%= post_url(slug: @post.slug) %>",
    "mainEntityOfPage": "<%= post_url(slug: @post.slug) %>",
    "wordCount": <%= @post.word_count %>,
    "image": "<%= @post.og_image %>",
    "author": {
      "@type": "Person",
      "@id": "https://hencf.org/#person",
      "name": "Henrique Cardoso de Faria"
    },
    "publisher": {
      "@type": "Person",
      "@id": "https://hencf.org/#person",
      "name": "Henrique Cardoso de Faria"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "<%= root_url %>"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Blog",
        "item": "<%= blog_url %>"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "<%= j @post.title %>"
      }
    ]
  }
]
</script>
<% end %>

<%= render "shared/nav", active: :blog, home: false %>

<main>
  <article class="section">
    <div class="container">
      <header class="post-header">
        <time class="post-date" datetime="<%= @post.published_at.iso8601 %>">
          <%= @post.published_at.strftime("%B %-d, %Y") %>
        </time>
        <h1 class="post-title"><%= @post.title %></h1>
      </header>

      <div class="post-body">
        <%= @post.body_html %>
      </div>

      <footer class="post-footer">
        <a href="/blog">&larr; Back to blog</a>
      </footer>
    </div>
  </article>
</main>

<footer class="footer">
  <div class="container">
    <p>
      Henrique Cardoso de Faria · <%= Date.current.year %>
      · <a href="<%= blog_feed_path %>">RSS feed</a>
    </p>
  </div>
</footer>
